rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Helpers
    // ============================================================
    function friendshipPair(a, b) {
      return a < b ? a + "__" + b : b + "__" + a;
    }
    function hasAcceptedFriendship(a, b) {
      let id = friendshipPair(a, b);
      return exists(/databases/$(database)/documents/friendships/$(id))
        && get(/databases/$(database)/documents/friendships/$(id)).data.status == "accepted";
    }
    function recipientDmsFrom(uid) {
      return get(/databases/$(database)/documents/publicProfiles/$(uid)).data.privacy.dmsFrom;
    }
    function canDmRecipient(uid) {
      return exists(/databases/$(database)/documents/publicProfiles/$(uid))
        && (
          recipientDmsFrom(uid) == "everyone"
          || (recipientDmsFrom(uid) == "friends"
              && hasAcceptedFriendship(request.auth.uid, uid))
        );
    }

    // ============================================================
    // Users — private. Only the owner can read/write their own doc.
    // The PUBLIC view of a user lives in /publicProfiles.
    // ============================================================
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ============================================================
    // Public profiles — denormalized, opt-in view of a user.
    // Written only by the owning user; readable by any signed-in
    // user IF the target has socialEnabled.
    // ============================================================
    match /publicProfiles/{uid} {
      // The owner can always read their own public profile (used to
      // preview + to idempotently sync/delete on privacy toggles).
      // Other users read only when the target opted into social.
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || resource.data.privacy.socialEnabled == true);
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow delete: if request.auth != null
        && request.auth.uid == uid;
    }

    // ============================================================
    // Aliases — uniqueness lock. Keyed by lowercase alias.
    // - Anyone signed in can read (to check availability / resolve).
    // - Create only if alias doc doesn't exist AND claimed-by matches
    //   the authenticated user.
    // - Delete only by the owning user.
    // ============================================================
    match /aliases/{alias} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ============================================================
    // Crews — group memberships. Public crews are discoverable by
    // anyone signed in. Invite-only crews are still readable (for
    // browsing) but joinable only with a pending invite.
    // ============================================================
    match /crews/{crewId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberCount == 1
        && (request.resource.data.visibility == "public"
            || request.resource.data.visibility == "invite-only");

      // Only the owner can modify or delete the crew. memberCount can
      // be adjusted by joinCrew/leaveCrew transactions which run as
      // the member themselves — special-case that so rules don't need
      // to reason about field-level writes.
      allow update: if request.auth != null
        && (
          // Owner edits
          resource.data.createdBy == request.auth.uid
          ||
          // Member joining adjusts memberCount
          (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['memberCount']))
        );

      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    match /crewMemberships/{id} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && (
          // Public crews — open join
          get(/databases/$(database)/documents/crews/$(request.resource.data.crewId)).data.visibility == "public"
          ||
          // Invite-only crews — require an existing invite
          exists(/databases/$(database)/documents/crewInvites/$(request.resource.data.crewId + "__" + request.auth.uid))
          ||
          // Owner creating their own membership at crew-creation time
          get(/databases/$(database)/documents/crews/$(request.resource.data.crewId)).data.createdBy == request.auth.uid
        );

      // Memberships are immutable (role/alias changes require delete + recreate).
      allow update: if false;

      // Self-leave, or owner kicks.
      allow delete: if request.auth != null
        && (resource.data.uid == request.auth.uid
            || get(/databases/$(database)/documents/crews/$(resource.data.crewId)).data.createdBy == request.auth.uid);
    }

    match /crewInvites/{id} {
      // Invitee and inviter can read their own invites.
      allow read: if request.auth != null
        && (resource.data.inviteeUid == request.auth.uid
            || resource.data.invitedBy == request.auth.uid);

      // Only the crew owner can create invites.
      allow create: if request.auth != null
        && request.resource.data.invitedBy == request.auth.uid
        && get(/databases/$(database)/documents/crews/$(request.resource.data.crewId)).data.createdBy == request.auth.uid;

      // Delete: invitee accepts/declines, or inviter cancels, or when
      // a membership is created the join-transaction cleans it up.
      allow delete: if request.auth != null
        && (resource.data.inviteeUid == request.auth.uid
            || resource.data.invitedBy == request.auth.uid);
    }

    // ============================================================
    // Posts — user-authored feed content. Visibility gates READ:
    //   public:    any signed-in user
    //   friends:   author, or an accepted friendship exists
    //   only-me:   author only (draft)
    // Author owns writes; reaction transactions adjust reactionCounts
    // and comment transactions adjust commentCount.
    // ============================================================
    match /posts/{postId} {
      allow read: if request.auth != null
        && (
          resource.data.visibility == "public"
          || resource.data.authorUid == request.auth.uid
          || (
            resource.data.visibility == "friends"
            && (
              (request.auth.uid < resource.data.authorUid
                && exists(/databases/$(database)/documents/friendships/$(request.auth.uid + "__" + resource.data.authorUid))
                && get(/databases/$(database)/documents/friendships/$(request.auth.uid + "__" + resource.data.authorUid)).data.status == "accepted")
              ||
              (resource.data.authorUid < request.auth.uid
                && exists(/databases/$(database)/documents/friendships/$(resource.data.authorUid + "__" + request.auth.uid))
                && get(/databases/$(database)/documents/friendships/$(resource.data.authorUid + "__" + request.auth.uid)).data.status == "accepted")
            )
          )
        );

      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.reactionCounts.push == 0
        && request.resource.data.reactionCounts.same == 0
        && request.resource.data.reactionCounts.fire == 0
        && request.resource.data.commentCount == 0;

      allow update: if request.auth != null
        && (
          // Author edits their own post
          resource.data.authorUid == request.auth.uid
          // Reaction / comment transactions adjust count fields only
          || request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['reactionCounts', 'commentCount'])
        );

      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;

      // Comments subcollection
      match /comments/{commentId} {
        // Comments inherit the parent post's read rules — not supported
        // declaratively, but if the viewer can't read the parent, reading
        // the comment doesn't reveal anything useful. We enforce read on
        // any authed user; parent visibility is the primary gate.
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.postId == postId;

        allow delete: if request.auth != null
          && (resource.data.authorUid == request.auth.uid
              || get(/databases/$(database)/documents/posts/$(postId)).data.authorUid == request.auth.uid);

        allow update: if false;
      }
    }

    match /postReactions/{id} {
      // Reactions readable by anyone authed — used to compute "did I react"
      // on the client. Privacy of a reaction is parent-post-bound.
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ============================================================
    // Conversations (1:1 DMs). Doc id is pairId(userA, userB). Create
    // gated by recipient's dmsFrom privacy + (if "friends") an accepted
    // friendship. Read/update by either participant.
    // ============================================================
    match /conversations/{convId} {
      allow read: if request.auth != null
        && (resource.data.userA == request.auth.uid
            || resource.data.userB == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.userA < request.resource.data.userB
        && request.resource.data.messageCount == 0
        && (request.resource.data.userA == request.auth.uid
            || request.resource.data.userB == request.auth.uid)
        && (
          // Self-recipient is nonsense but sender must be a participant;
          // the recipient is whoever isn't the sender in the pair.
          (request.resource.data.userA == request.auth.uid
            && canDmRecipient(request.resource.data.userB))
          ||
          (request.resource.data.userB == request.auth.uid
            && canDmRecipient(request.resource.data.userA))
        );

      allow update: if request.auth != null
        && (resource.data.userA == request.auth.uid
            || resource.data.userB == request.auth.uid);

      allow delete: if false;

      match /messages/{msgId} {
        allow read: if request.auth != null
          && (get(/databases/$(database)/documents/conversations/$(convId)).data.userA == request.auth.uid
              || get(/databases/$(database)/documents/conversations/$(convId)).data.userB == request.auth.uid);

        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid
          && (get(/databases/$(database)/documents/conversations/$(convId)).data.userA == request.auth.uid
              || get(/databases/$(database)/documents/conversations/$(convId)).data.userB == request.auth.uid);

        allow update, delete: if false;
      }
    }

    // ============================================================
    // Live presence — each user owns /livePresence/{uid}.
    // Any authed user can read to populate the Live Now widget.
    // ============================================================
    match /livePresence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ============================================================
    // Meetups — public or crew-only sessions. Host is always the
    // creator. goingCount is adjusted by the RSVP transaction which
    // runs as the rsvping member, so updates are allowed if either
    // the host is editing OR the only affected key is goingCount.
    // ============================================================
    match /meetups/{meetupId} {
      allow read: if request.auth != null
        && (
          resource.data.visibility == "public"
          || (resource.data.visibility == "crew-only"
              && exists(/databases/$(database)/documents/crewMemberships/$(resource.data.crewId + "__" + request.auth.uid)))
          || resource.data.hostUid == request.auth.uid
        );

      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.goingCount == 1
        && (request.resource.data.visibility == "public"
            || request.resource.data.visibility == "crew-only")
        && (
          request.resource.data.visibility == "public"
          || (request.resource.data.visibility == "crew-only"
              && exists(/databases/$(database)/documents/crewMemberships/$(request.resource.data.crewId + "__" + request.auth.uid)))
        );

      allow update: if request.auth != null
        && (
          // Host edits
          resource.data.hostUid == request.auth.uid
          // RSVP transaction adjusts goingCount only
          || (request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['goingCount']))
        );

      allow delete: if request.auth != null
        && resource.data.hostUid == request.auth.uid;
    }

    match /meetupRsvps/{id} {
      // Authed users can read RSVPs for any meetup (list attendees).
      // In practice the meetup's own read rule gates visibility of the
      // parent object; if someone can't see the meetup, the attendee
      // list is irrelevant to them.
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ============================================================
    // Friendships — one doc per pair, keyed by sorted UIDs.
    // Read/write gated on being one of the two parties.
    // ============================================================
    match /friendships/{id} {
      allow read: if request.auth != null
        && (resource.data.userA == request.auth.uid
            || resource.data.userB == request.auth.uid);

      // Create: must be the initiator, must be one of the two parties,
      // doc ID must match the sorted-pair canonical form.
      allow create: if request.auth != null
        && request.resource.data.initiatedBy == request.auth.uid
        && (request.resource.data.userA == request.auth.uid
            || request.resource.data.userB == request.auth.uid)
        && request.resource.data.userA < request.resource.data.userB
        && request.resource.data.status == "pending";

      // Update: only to accept (pending -> accepted), and only by the
      // recipient (i.e. not the initiator).
      allow update: if request.auth != null
        && (resource.data.userA == request.auth.uid
            || resource.data.userB == request.auth.uid)
        && resource.data.initiatedBy != request.auth.uid
        && resource.data.status == "pending"
        && request.resource.data.status == "accepted"
        // Don't let anyone rewrite the core identity fields on accept
        && request.resource.data.userA == resource.data.userA
        && request.resource.data.userB == resource.data.userB
        && request.resource.data.initiatedBy == resource.data.initiatedBy;

      // Delete: either party can cancel/decline/unfriend.
      allow delete: if request.auth != null
        && (resource.data.userA == request.auth.uid
            || resource.data.userB == request.auth.uid);
    }

    // ============================================================
    // Blocks — each user manages their own block list; nobody else
    // can see it.
    // ============================================================
    match /blocks/{id} {
      allow read: if request.auth != null
        && resource.data.blockerUid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.blockerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.blockerUid == request.auth.uid;
      allow update: if false;
    }

    // ============================================================
    // Moderation queue — write-only from the client (to report content).
    // Reads happen server-side by future moderation tooling.
    // ============================================================
    match /moderation_queue/{id} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ============================================================
    // Sessions — owner-only.
    // ============================================================
    match /sessions/{sessionId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // YouTube cache — readable by any authed user, server writes.
    // ============================================================
    match /youtubeCache/{docId} {
      allow read: if request.auth != null;
    }
  }
}
